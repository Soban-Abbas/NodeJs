<%- include("../includes/head.ejs") %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/product.css">
    </head>

    <%- include("../includes/nav.ejs") %>

        <main>
            <form class="product-form" action= "<%= (edit)?'/admin/edit-product':'/admin/add-product'  %>" method="POST">
            
                <input type="hidden" name="productID" value="<%= (edit) ? product._id : null %>"   > 
                

                <div class="form-control">
                    <label for="title">Title</label>
                    <input type="text" name="title" id="title" value="<%if(product){%><%=product.title %><%}%>" >
                </div>
                <div class="form-control">
                    <label for="price">Price</label>
                    <input type="text" name="price" id="price" value="<%if(product){%><%=product.price %><%}%>">
                </div>
                <div class="form-control">
                    <label for="img">Image</label>
                    <input type="url" name="image" id="img" value="<%if(product){%><%=product.image%><%}%>" >
                </div>
                <div class="form-control">
                    <label for="Dis">Description</label>
                    <input type="text" name="discription" id="Dis" value="<%if(product){%><%=product.discription%><%}%>">
                </div>
                 <% if(edit){ %>
                    <button class="btn" type="submit">Update Product</button>
                    <% }else{ %>
                <button class="btn" type="submit">Add Product</button>
                <%} %>
            </form>
        </main>

        <%- include("../includes/end.ejs")%>