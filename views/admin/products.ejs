<%- include("../includes/head.ejs")%>
    <link rel="stylesheet" href="/css/form.css">
    <link rel="stylesheet" href="/css/product.css">
    </head>

    <%- include("../includes/nav.ejs")%>

        <main>
            <% if(productArray.length!=0){ %>
                <% for(let book of productArray){ %>
                    <div class="grid">
                        <article class="card product-item">
                            <header class="card__header">
                                <h1 class="product__title">
                                    <%=book.title%>
                                </h1>
                            </header>
                            <div class="card__image">
                                <img src=<%= book.image%>
                                    alt="A Book">
                            </div>
                            <div class="card__content">
                                <h2 class="product__price"><%= book.price%></h2>
                                <p class="product__description"><%= book.discription %></p>
                            </div>
                            <div class="card__actions">
                              <a href="/admin/edit-product/<%= book.id %>?edit=true"><button class="btn">Edit</button></a>  
                               <a href="/admin/delete-product"><button class="btn">Delete</button></a> 
                            </div>
                            
                        </article>
                    </div>
                    <%}%>
                        <%} else{%>
                            <p>Product Not Available</p>
                            <% }%>
        </main>

        <%-include("../includes/end.ejs")%>